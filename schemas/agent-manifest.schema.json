{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aihlp/itinai/schemas/agent-manifest.schema.json",
  "title": "Itinai Agent Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["agent_id", "name", "a2a_config", "skills", "contact"],
  "properties": {
    "agent_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "a2a_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_card_url", "protocol_version"],
      "properties": {
        "agent_card_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "protocol_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "tags"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 50
            },
            "uniqueItems": true
          }
        }
      }
    },
    "dynamic_data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "catalogue_feed_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "negotiation_protocol": {
          "type": "string",
          "enum": ["ANP"]
        },
        "negotiation_endpoint": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      },
      "dependentRequired": {
        "negotiation_protocol": ["negotiation_endpoint"],
        "negotiation_endpoint": ["negotiation_protocol"]
      }
    },
    "openclaw": {
      "type": "object",
      "additionalProperties": true
    },
    "health_check": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["email"],
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      }
    }
  }
}
